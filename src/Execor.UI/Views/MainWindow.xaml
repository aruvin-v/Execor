<Window x:Class="Execor.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Execor"
        Width="1200"
        Height="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize" 
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgBase}"
            CornerRadius="12"
            BorderBrush="#2A2A2A"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.6" ShadowDepth="0" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource BgSidebar}"
                    CornerRadius="12,0,0,12">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Height="52"
                            Background="Transparent"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                        <Grid Margin="16,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="8" Height="8"
                                        Background="{StaticResource AccentBlue}"
                                        CornerRadius="4"
                                        Margin="0,0,8,0"/>
                                <TextBlock Text="Execor"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Padding="14,0,14,10">
                        <Button x:Name="NewChatButton"
                                Style="{StaticResource SidebarNewChatButton}"
                                HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold" Margin="0,0,6,0" Foreground="White"/>
                                <TextBlock Text="New Chat" FontSize="14" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="14,0,14,10"
                            Background="{StaticResource BgPanel}"
                            CornerRadius="10"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="MODEL" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="ModelSelector" Style="{StaticResource DarkComboBox}" Grid.Column="0" Margin="0,0,6,0"/>
                                <Button x:Name="RefreshModelsButton" Style="{StaticResource GhostButton}" Grid.Column="1" Padding="8,6" ToolTip="Refresh Models">
                                    <TextBlock Text="↻" FontSize="15" Foreground="{StaticResource TextSecondary}"/>
                                </Button>
                            </Grid>

                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,2,0,10"/>

                            <TextBlock Text="SYSTEM" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,6">
                                    <TextBlock Style="{StaticResource StatLabel}" Text="GPU"/>
                                    <TextBlock x:Name="GpuNameText" Style="{StaticResource StatValue}" Foreground="{StaticResource GreenColor}" Text="Detecting..." TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,4,6">
                                    <TextBlock Style="{StaticResource StatLabel}" Text="CUDA"/>
                                    <TextBlock x:Name="CudaStatusText" Style="{StaticResource StatValue}" Foreground="{StaticResource OrangeColor}" Text="Checking..."/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="4,0,0,6">
                                    <TextBlock Style="{StaticResource StatLabel}" Text="GPU Usage"/>
                                    <TextBlock x:Name="GpuUsageText" Style="{StaticResource StatValue}" Foreground="{StaticResource GreenColor}" Text="0%"/>
                                </StackPanel>

                                <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,4,6">
                                    <TextBlock Style="{StaticResource StatLabel}" Text="VRAM"/>
                                    <TextBlock x:Name="GpuMemoryText" Style="{StaticResource StatValue}" Foreground="{StaticResource TextPrimary}" Text="0 / 0 MB"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Grid.Row="2" Margin="4,0,0,6">
                                    <TextBlock Style="{StaticResource StatLabel}" Text="CPU"/>
                                    <TextBlock x:Name="CpuUsageText" Style="{StaticResource StatValue}" Foreground="{StaticResource BlueColor}" Text="0%"/>
                                </StackPanel>

                                <StackPanel Grid.Column="0" Grid.Row="3" Margin="0,0,4,0">
                                    <TextBlock Style="{StaticResource StatLabel}" Text="RAM"/>
                                    <TextBlock x:Name="RamUsageText" Style="{StaticResource StatValue}" Foreground="{StaticResource BlueColor}" Text="0 / 0 GB"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Grid.Row="3" Margin="4,0,0,0">
                                    <TextBlock Style="{StaticResource StatLabel}" Text="Speed"/>
                                    <TextBlock x:Name="TokensPerSecText" Style="{StaticResource StatValue}" Foreground="{StaticResource GoldColor}" Text="0 tok/s"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,8,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox x:Name="WebSearchToggle" 
                                          VerticalAlignment="Center"
                                          Cursor="Hand">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <Grid Background="Transparent">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border x:Name="Box" Width="16" Height="16" 
                                                            CornerRadius="4" BorderThickness="1" 
                                                            BorderBrush="{StaticResource TextMuted}" 
                                                            Background="{StaticResource BgInput}"
                                                            Margin="0,0,8,0">
                                                        <TextBlock x:Name="Check" Text="✓" FontSize="10" 
                                                                   Foreground="White" Visibility="Collapsed" 
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Text="Web Search" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                                </StackPanel>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentBlue}"/>
                                                    <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                                    <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>
                                <TextBlock Text="🌐" Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center" Opacity="0.7"/>
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,8,0,8"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Model Load: " FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="ModelLoadTimeText" Text="0 sec" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource GoldColor}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="3" Margin="14,0,14,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="CHATS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,8"/>

                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <TextBox x:Name="SearchChatsInput" Style="{StaticResource DarkTextBox}" Height="34" Padding="30,8,10,8" FontSize="13"/>
                            <TextBlock Text="🔍" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource TextMuted}" IsHitTestVisible="False"/>
                        </Grid>

                        <ScrollViewer Grid.Row="2" Style="{StaticResource DarkScrollViewer}" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ConversationListPanel"/>
                        </ScrollViewer>
                    </Grid>

                    <Button Grid.Row="4" x:Name="DatabaseButton" Content="🗄 Connect Database" 
                            Style="{StaticResource GhostButton}" Margin="14,0,14,5" 
                            HorizontalAlignment="Stretch" Click="DatabaseButton_Click"/>

                    <Button Grid.Row="5" x:Name="SettingsButton" Content="⚙ Settings" 
                            Style="{StaticResource GhostButton}" Margin="14,0,14,14" 
                            HorizontalAlignment="Stretch" Click="SettingsButton_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource BgHeader}"
                        CornerRadius="0,12,0,0"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="20,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Execor" FontSize="17" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text=" AI Assistant" FontSize="17" FontWeight="Normal" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>

                        <TextBlock x:Name="TypingStatus" Grid.Column="1" VerticalAlignment="Center" FontSize="13" FontStyle="Italic" Foreground="{StaticResource AccentBlue}" Opacity="0.8" Margin="0,0,15,0"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="MinimizeButton" Style="{StaticResource GhostButton}" Padding="6" Click="MinimizeButton_Click" ToolTip="Minimize">
                                <TextBlock Text="—" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                            <Button x:Name="MaximizeButton" Style="{StaticResource GhostButton}" Padding="6" Click="MaximizeButton_Click" ToolTip="Maximize">
                                <TextBlock Text="⬜" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                            <Button x:Name="CloseButton" Style="{StaticResource GhostButton}" Padding="6" Click="CloseButton_Click" ToolTip="Close">
                                <TextBlock Text="✕" FontSize="12" Foreground="#EF5350"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer x:Name="ChatScrollViewer"
                              Grid.Row="1"
                              Style="{StaticResource DarkScrollViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="24,20">
                    <StackPanel x:Name="MessagesPanel" HorizontalAlignment="Stretch"/>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="{StaticResource BgPanel}"
                        CornerRadius="0,0,12,0"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,1,0,0"
                        Padding="20,14">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Popup x:Name="SlashCommandPopup" 
                               PlacementTarget="{Binding ElementName=InputBorder}" 
                               Placement="Top" 
                               IsOpen="False" 
                               StaysOpen="False"
                               AllowsTransparency="True"
                               VerticalOffset="-5">
                            <Border Background="{StaticResource BgPanel}" 
                                    BorderBrush="{StaticResource AccentBlue}" 
                                    BorderThickness="1" 
                                    CornerRadius="8" 
                                    Padding="5"
                                    Width="{Binding ElementName=InputBorder, Path=ActualWidth}">
                                <ListBox x:Name="CommandListBox" 
                                         Background="Transparent" 
                                         BorderThickness="0" 
                                         Foreground="White" 
                                         FontSize="14"
                                         SelectionChanged="CommandListBox_SelectionChanged"/>
                            </Border>
                        </Popup>

                        <Border Grid.Column="0"
                                Background="{StaticResource BgInput}"
                                CornerRadius="10"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                Margin="0,0,10,0"
                                x:Name="InputBorder">
                            <Grid>
                                <TextBox x:Name="PromptInput"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{StaticResource TextPrimary}"
                                         FontSize="14"
                                         Padding="14,10"
                                         TextWrapping="Wrap"
                                         MinHeight="44"
                                         MaxHeight="160"
                                         VerticalScrollBarVisibility="Auto"
                                         CaretBrush="{StaticResource AccentBlue}"
                                         SelectionBrush="{StaticResource AccentBlue}"
                                         VerticalContentAlignment="Top"
                                         PreviewKeyDown="PromptInput_PreviewKeyDown"
                                         KeyDown="PromptInput_KeyDown"
                                         AcceptsReturn="True"/>
                                <TextBlock x:Name="PromptPlaceholder"
                                           Text="Message Execor... (Enter to send, Shift+Enter for newline)"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="14"
                                           Margin="14,10,14,10"
                                           VerticalAlignment="Top"
                                           IsHitTestVisible="False"
                                           Visibility="Visible"/>
                            </Grid>
                        </Border>

                        <Button x:Name="StopButton" Grid.Column="1" Style="{StaticResource StopButton}" Margin="0,0,8,0" Visibility="Collapsed" MinWidth="70" VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏹" FontSize="12" Margin="0,0,5,0"/>
                                <TextBlock Text="Stop"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="SendButton" Grid.Column="2" Style="{StaticResource PrimaryButton}" MinWidth="80" VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Send" Margin="0,0,5,0"/>
                                <TextBlock Text="↑" FontSize="15" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
                <Frame x:Name="SettingsFrame" Grid.Row="1" Grid.RowSpan="2" 
                       NavigationUIVisibility="Hidden" Visibility="Collapsed" 
                       Background="{StaticResource BgBase}" Panel.ZIndex="10"/>
            </Grid>
        </Grid>
    </Border>
</Window>