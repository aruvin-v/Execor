<Page x:Class="Execor.UI.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBase}">

    <StackPanel Margin="30" MaxWidth="600" HorizontalAlignment="Left">
        <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,30"/>

        <TextBlock Text="Models Directory" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ModelsPathInput" Style="{StaticResource DarkTextBox}"/>
            <Button x:Name="BrowseFolderBtn" Content="Browse" Grid.Column="1" Margin="10,0,0,0" Style="{StaticResource GhostButton}" Click="BrowseFolderBtn_Click"/>
        </Grid>

        <TextBlock Text="Default Context Size" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
        <TextBox x:Name="ContextSizeInput" Style="{StaticResource DarkTextBox}" Width="150" HorizontalAlignment="Left" Margin="0,0,0,30"/>

        <TextBlock Text="Active MCP Tools" FontSize="18" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,10"/>
        <Border Background="#0A0A0A" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,30">
            <ScrollViewer MaxHeight="250" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="McpToolsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A1A" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Items.Count, RelativeSource={RelativeSource Self}}" Value="0">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate>
                                                <TextBlock Text="No MCP tools currently connected." Foreground="{StaticResource TextMuted}" FontStyle="Italic" HorizontalAlignment="Center" Margin="10"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Orientation="Horizontal">
            <Button x:Name="SaveSettingsBtn" Content="Save Changes" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="SaveSettingsBtn_Click"/>
            <Button x:Name="CloseBtn" Content="Close" Style="{StaticResource GhostButton}" Click="CloseBtn_Click"/>
        </StackPanel>
    </StackPanel>
</Page>